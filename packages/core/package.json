{
  "name": "agentcost",
  "version": "0.2.0",
  "description": "Lightweight cost tracking and optimization for AI agent systems",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test src/AgentCost.test.ts src/report.test.ts src/wrappers.test.ts src/proxy.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "cost",
    "tokens",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "budget",
    "tracking"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
